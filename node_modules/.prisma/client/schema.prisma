// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RoleDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  permissions Json // JSON array of permissions
  isSystem    Boolean  @default(false) // System roles cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Performance indexes
  @@index([name])
  @@index([isSystem])
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  username           String              @unique
  password           String
  name               String
  role               String              @default("USER")
  authorizedBrands   UserBrand[]
  customers          Customer[]
  corporateCustomers CorporateCustomer[]
  sales              Sale[]              @relation("UserSales")
  corporateSales     CorporateSale[]     @relation("UserCorporateSales")
  accessorySales     AccessorySale[]     @relation("UserAccessorySales")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Performance indexes
  @@index([email])
  @@index([role])
  @@index([createdAt])
}

model Brand {
  id              String      @id @default(cuid())
  name            String      @unique
  models          Model[]
  accessories     Accessory[]
  authorizedUsers UserBrand[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Performance indexes
  @@index([name])
  @@index([createdAt])
}

model Model {
  id          String      @id @default(cuid())
  name        String
  brand       Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId     String
  packages    Package[]
  accessories Accessory[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([name, brandId])
  // Performance indexes
  @@index([brandId])
  @@index([name])
  @@index([createdAt])
}

model Package {
  id           String   @id @default(cuid())
  name         String
  model        Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  modelId      String
  mtvAmount    Float
  plakaMasrafi Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([name, modelId])
}

model Accessory {
  id        String   @id @default(cuid())
  name      String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId   String
  model     Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  modelId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, brandId, modelId])
}

model UserBrand {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId   String
  createdAt DateTime @default(now())

  @@unique([userId, brandId])
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  tcNo          String   @unique
  birthDate     String?
  occupation    String?
  address       String?
  cityId        Int?
  districtId    Int?
  status        String   @default("Aktif")
  registerDate  String
  createdBy     String // Hangi kullanıcının eklediğini takip etmek için
  createdByUser User     @relation(fields: [createdBy], references: [id])
  sales         Sale[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Performance indexes
  @@index([email])
  @@index([phone])
  @@index([tcNo])
  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
}

model CorporateCustomer {
  id               String          @id @default(cuid())
  name             String
  taxNumber        String          @unique
  taxOffice        String
  email            String
  phone            String
  address          String
  cityId           Int
  districtId       Int
  status           String          @default("Aktif")
  registerDate     String
  authorizedPerson String?
  createdBy        String // Hangi kullanıcının eklediğini takip etmek için
  createdByUser    User            @relation(fields: [createdBy], references: [id])
  sales            CorporateSale[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Performance indexes
  @@index([email])
  @@index([phone])
  @@index([taxNumber])
  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
}

model Sale {
  id                 String          @id @default(cuid())
  customer           Customer        @relation(fields: [customerId], references: [id])
  customerId         String
  model              String
  chassisNo          String
  engineNo           String
  purchaseDate       String
  salePrice          Float
  purchasePrice      Float
  contributionAmount Float
  mtvCost            Float
  licensePlateCost   Float
  color              String
  saleType           String? // Satış tipi: Perakende, Filo, ÖTV Muaf
  packageId          String?
  packageName        String?
  extraAmount        Float? // Ekstra tutar
  otvRate            Float? // ÖTV oranı (%)
  kdvRate            Float? // KDV oranı (%)
  accessorySales     AccessorySale[] @relation("SaleAccessories")
  createdBy          String // Hangi kullanıcının eklediğini takip etmek için
  createdByUser      User            @relation("UserSales", fields: [createdBy], references: [id])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Performance indexes
  @@index([customerId])
  @@index([createdBy])
  @@index([model])
  @@index([purchaseDate])
  @@index([createdAt])
}

model CorporateSale {
  id                 String            @id @default(cuid())
  customer           CorporateCustomer @relation(fields: [customerId], references: [id])
  customerId         String
  model              String
  chassisNo          String
  engineNo           String
  purchaseDate       String
  salePrice          Float
  purchasePrice      Float
  contributionAmount Float
  mtvCost            Float
  licensePlateCost   Float
  color              String
  saleType           String? // Satış tipi: Perakende, Filo, ÖTV Muaf
  packageId          String?
  packageName        String?
  extraAmount        Float? // Ekstra tutar
  otvRate            Float? // ÖTV oranı (%)
  kdvRate            Float? // KDV oranı (%)
  createdBy          String // Hangi kullanıcının eklediğini takip etmek için
  createdByUser      User              @relation("UserCorporateSales", fields: [createdBy], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // Performance indexes
  @@index([customerId])
  @@index([createdBy])
  @@index([model])
  @@index([purchaseDate])
  @@index([createdAt])
}

model AccessorySale {
  id             String   @id @default(cuid())
  customerName   String // Müşteri adı ve soyadı
  customerTcNo   String? // Müşteri TC kimlik numarası (opsiyonel)
  vehicleBrand   String // Araç markası
  vehicleModel   String // Araç modeli
  vehiclePackage String // Araç paketi
  licensePlate   String? // Plaka numarası (opsiyonel)
  chassisNo      String? // Şasi numarası (opsiyonel)
  engineNo       String? // Motor numarası (opsiyonel)
  accessoryName  String // Aksesuar adı
  accessoryPrice Float // Aksesuar fiyatı
  saleDate       String // Satış tarihi
  saleId         String? // Araç satışı ile bağlantı (opsiyonel)
  sale           Sale?    @relation("SaleAccessories", fields: [saleId], references: [id])
  createdBy      String // Hangi kullanıcının eklediğini takip etmek için
  createdByUser  User     @relation("UserAccessorySales", fields: [createdBy], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Performance indexes
  @@index([customerTcNo])
  @@index([vehicleBrand])
  @@index([vehicleModel])
  @@index([saleDate])
  @@index([createdBy])
  @@index([createdAt])
  @@index([saleId])
}

model MaintenanceProduct {
  id          String   @id @default(cuid())
  name        String // Ürün adı
  description String? // Ürün açıklaması
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Performance indexes
  @@index([name])
  @@index([createdAt])
}
